# Azure AI Foundry — Chat Completions (LLM)
AZURE_AI_ENDPOINT="https://<resource>.openai.azure.com/"
AZURE_AI_KEY="<key>"
AZURE_AI_DEPLOYMENT="<chat-completions-deployment-name>"
AZURE_AI_API_VERSION="2024-10-21"

# Azure Cognitive Services Speech — TTS only (STT now via GPT Realtime API)
AZURE_SPEECH_KEY="<key>"
AZURE_SPEECH_REGION="swedencentral"
# AZURE_SPEECH_ENDPOINT=""
# AZURE_TTS_VOICE="en-US-Ava:DragonHDLatestNeural"

# --- GPT Realtime API (STT + VAD) ---
# Azure OpenAI Realtime (preferred):
AZURE_REALTIME_ENDPOINT="https://<resource>.openai.azure.com/"
AZURE_REALTIME_DEPLOYMENT="gpt-4o-realtime-preview"
AZURE_REALTIME_KEY="<key>"
# OpenAI direct (fallback if Azure vars not set):
# OPENAI_REALTIME_KEY="<key>"
# OPENAI_REALTIME_MODEL="gpt-4o-realtime-preview"

# Mongo
MONGO_URI="mongodb://localhost:27017/opint"
# MONGO_DB="opint"

# Node server
PORT=3001

# --- Python LangGraph agent (sidecar) ---
PY_AGENT_URL="http://localhost:8001"
PY_AGENT_PORT=8001
